# Copy this file to .env and fill in real values (.env is gitignored)

# Server
PORT=3001

# Circle — see Circle Developer Console (https://console.circle.com) for these values
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_OPERATOR_WALLET_ID=
CIRCLE_OPERATOR_ADDRESS=

# Arc Testnet
ARC_RPC_URL=https://rpc.testnet.arc.network

# PactWrapper — current Arc Testnet deployment. Override only if redeploying.
WRAPPER_ADDRESS=0x4183b1429eE2467772b4612a94Ef253210312F02

# Standalone escrow stack — set after `forge script DeployTradePass`.
TRADE_ESCROW_ADDRESS=
TRADE_PASSPORT_ADDRESS=
FINANCING_POOL_ADDRESS=

# Trade Officer agent: trades at/above this USDC value escalate to a human verifier.
OFFICER_HIGH_VALUE_USDC=5000

# Buyer challenge window: seconds the officer waits after approving a delivery
# doc before it auto-settles, during which the buyer can dispute. Default 30.
OFFICER_CHALLENGE_WINDOW_SECONDS=30

# LLM documentary verifier (OpenRouter, OpenAI-compatible). Leave OPENROUTER_API_KEY
# blank to fall back to the deterministic regex check. OFFICER_LLM_MODEL is optional.
OPENROUTER_API_KEY=
OFFICER_LLM_MODEL=google/gemini-2.0-flash-001
