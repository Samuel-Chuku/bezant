# Bezant BACKEND env (VPS) — copy to `.env` (gitignored) next to docker-compose.yml.
# docker compose passes these into the backend container via `env_file`.
#
# The FRONTEND is on Vercel: set its NEXT_PUBLIC_* vars in the Vercel dashboard,
# NOT here. For reference, Vercel needs:
#   NEXT_PUBLIC_API_BASE=https://api.bezant.trade
#   NEXT_PUBLIC_APP_URL=https://app.bezant.trade
#   NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...
#   NEXT_PUBLIC_CIRCLE_CLIENT_KEY=...
#   NEXT_PUBLIC_CIRCLE_CLIENT_URL=...
#   NEXT_PUBLIC_CIRCLE_CHAIN_ALIAS=arcTestnet

# ── CORS: the browser origin(s) that call this API = the app subdomain ────────
CORS_ORIGINS=https://app.bezant.trade

# ── Arc RPC ──────────────────────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network

# ── Circle (developer-controlled wallets) ────────────────────────────────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
CIRCLE_OPERATOR_WALLET_ID=
CIRCLE_OPERATOR_ADDRESS=

# ── Deployed contract addresses (Arc Testnet) ────────────────────────────────
WRAPPER_ADDRESS=0x4183b1429eE2467772b4612a94Ef253210312F02
TRADE_ESCROW_ADDRESS=
TRADE_PASSPORT_ADDRESS=
FINANCING_POOL_ADDRESS=
STAKED_VERIFIER_ADDRESS=
ARC_REPUTATION_REGISTRY_ADDRESS=
ARC_IDENTITY_REGISTRY_ADDRESS=
# Indexer start block — the block TradeEscrow was deployed at.
TRADE_ESCROW_DEPLOY_BLOCK=45662878

# ── Trade Officer + documentary verifier ─────────────────────────────────────
OFFICER_HIGH_VALUE_USDC=5000
OFFICER_CHALLENGE_WINDOW_SECONDS=30
# Leave OPENROUTER_API_KEY blank to fall back to the deterministic regex check.
OPENROUTER_API_KEY=
OFFICER_LLM_MODEL=google/gemini-2.0-flash-001

# ── Optional ─────────────────────────────────────────────────────────────────
# Gateway cross-chain payout relayer (leave blank to disable).
GATEWAY_RELAYER_PRIVATE_KEY=
# Guards admin-only routes; leave blank to disable them.
ADMIN_API_KEY=
