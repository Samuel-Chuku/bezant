# Get a free project ID at https://cloud.reown.com (formerly WalletConnect Cloud).
# Required for RainbowKit's wallet-connect support.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID_HERE

# Backend base URL. Defaults to the local dev server.
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Circle Modular Wallets (passkey-backed smart accounts).
# Sign up at https://console.circle.com, create a Modular Wallets project,
# and copy the Client Key + Client URL from "Configurator".
# The CLIENT_KEY is also stored backend-side (CIRCLE_CLIENT_KEY in Arc/.env);
# the same key is safe to expose to the frontend.
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=YOUR_CIRCLE_CLIENT_KEY_HERE
NEXT_PUBLIC_CIRCLE_CLIENT_URL=YOUR_CIRCLE_CLIENT_URL_HERE
# Chain alias appended to CLIENT_URL when calling toModularTransport.
# Defaults to "arcTestnet" — change if Circle's actual alias differs.
NEXT_PUBLIC_CIRCLE_CHAIN_ALIAS=arcTestnet

# Product-feedback webhook. The feedback page/widget POSTs submissions here
# (pure passthrough). Point it at your n8n webhook, which fans out to the
# Google Sheet + Telegram alert. Leave unset to disable the send.
NEXT_PUBLIC_FEEDBACK_WEBHOOK_URL=
